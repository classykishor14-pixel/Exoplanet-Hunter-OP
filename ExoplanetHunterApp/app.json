{
  "expo": {
    "name": "Exoplanet Hunter",
    "slug": "exoplanet-hunter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0a0a1a",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.exoplanethunter.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a1a"
      },
      "package": "com.exoplanethunter.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#0a0a1a"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Exoplanet Hunter to access your camera for AR star mapping."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "exoplanet-hunter"
      }
    }
  }
}
